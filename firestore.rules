rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /organizations/{orgId} {
      allow read: if true;
      allow write: if true; 
    }

    match /metrics/{metricId} {
      allow read: if true;
      allow write: if true;
    }

    match /auditLogs/{logId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }
  }
}
